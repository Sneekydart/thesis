import serial
import time

ser = serial.Serial(
    port='/dev/ttyUSB0',
    baudrate=9600,
    bytesize=8,
    parity='N',
    stopbits=1,
    timeout=2
)

# 50°C command
cmd_50 = bytes([0xFE, 0xB2, 0x00, 0x32, 0x00, 0xE4])

# 20°C command
cmd_20 = bytes([0xFE, 0xB2, 0x00, 0x14, 0x00, 0xC6])

# Send 50°C
ser.write(cmd_50)
print("Set to 50°C")

time.sleep(10)  # wait 10 seconds

# Send 20°C
ser.write(cmd_20)
print("Set to 20°C")

ser.close()