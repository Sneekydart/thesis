import serial
import time

ser = serial.Serial(
    port='/dev/ttyUSB0',
    baudrate=9600,
    bytesize=8,
    parity='N',
    stopbits=1,
    timeout=2
)

# Correct packet for 50°C
packet = bytes([0xFE, 0xB2, 0x00, 0x32, 0x00, 0xE4])

ser.write(packet)

time.sleep(0.5)

response = ser.read(6)

print("Raw:", response)
print("Hex:", response.hex())

ser.close()